{
  "$schema": "https://opencode.ai/config.json",
  "enabled_providers": ["zai-coding-plan", "opencode"],
  "model": "zai-coding-plan/glm-5",
  "provider": {
    "zai-coding-plan": {
      "options": {
        "apiKey": "{env:ZAI_CODING_PLAN_API_KEY}"
      }
    },
    "opencode": {
      "options": {
        "apiKey": "{env:OPENCODE_API_KEY}"
      }
    }
  }
}
